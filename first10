<script>
let cur='s-onboard', prev='s-onboard';
const doneSteps={};
let bt=null, userName='';
let activeTheme='gold';
const PREF_KEY='first10-prefs';
const NAME_KEY='first10-name';
const THEME_KEY='first10-theme';

/* ── ONBOARDING ── */
function startApp(){
  const n=document.getElementById('ob-name').value.trim();
  if(!n){ document.getElementById('ob-name').style.borderColor='var(--gold)'; document.getElementById('ob-name').focus(); return; }
  userName=n;
  localStorage.setItem(NAME_KEY,userName);
  document.getElementById('dd-username').textContent='👋 Hey, '+n;
  document.getElementById('set-name').value=n;
  setGreeting(n);
  go('s-home');
}
function setGreeting(name){
  const h=new Date().getHours();
  const p=h<12?'morning':h<17?'afternoon':'evening';
  document.getElementById('greeting-h1').textContent='Good '+p+', '+name+'.';
}
function updateName(v){
  if(v.trim()){
    userName=v.trim();
    localStorage.setItem(NAME_KEY,userName);
    setGreeting(userName);
    document.getElementById('dd-username').textContent='👋 Hey, '+userName;
  }
}

/* ── NAVIGATION ── */
function go(id){
  document.getElementById(cur).classList.remove('active');
  prev=cur; cur=id;
  document.getElementById(id).classList.add('active');
  if(id==='s-mind') startBreath();
}
function back(){
  document.getElementById(cur).classList.remove('active');
  cur=prev; document.getElementById(cur).classList.add('active');
}

/* ── CHECK IN ── */
function pickSleep(el,val){
  el.closest('.mg').querySelectorAll('.mc').forEach(c=>c.classList.remove('sel'));
  el.classList.add('sel');
  document.getElementById('sleep-disp').textContent=val;
}

/* ── STEP COMPLETE ── */
function complete(n,nxt){
  doneSteps[n]=true;
  document.getElementById('c'+n).classList.add('done');
  const d=document.getElementById('d'+n); if(d) d.style.display='block';
  const cnt=Object.keys(doneSteps).length;
  const btn=document.getElementById('home-cta');
  if(cnt===5) btn.innerHTML='See you tomorrow. ☀️';
  else btn.innerHTML='Continue ('+cnt+'/5 done) →';
  go(nxt);
}

/* ── FOCUS ── */
function saveFocus(){
  const main=document.getElementById('inp-main').value.trim()||'My main goal';
  const per=document.getElementById('inp-per').value.trim()||'Personal growth';
  const grat=document.getElementById('inp-grat').value.trim()||'Today';
  document.getElementById('disp-main').textContent=main;
  document.getElementById('disp-per').textContent=per;
  document.getElementById('disp-grat').textContent=grat;
  document.getElementById('li-main').textContent=main;
  complete(2,'s-mind');
}

/* ── MODES & TASKS ── */
function selMode(el){ el.closest('.modes').querySelectorAll('.mcard').forEach(c=>c.classList.remove('sel')); el.classList.add('sel'); }
function tgl(el){ el.classList.toggle('done'); }

/* ── BREATHING ── */
const phases=[{lbl:'Breathe In',n:4},{lbl:'Hold',n:4},{lbl:'Breathe Out',n:4},{lbl:'Hold',n:4}];
let ph=0,bc=4;
function startBreath(){ ph=0;bc=4;stopBreath();upBreath(); bt=setInterval(()=>{ bc--;if(bc<=0){ph=(ph+1)%4;bc=phases[ph].n;}upBreath(); },1000); }
function stopBreath(){ if(bt){clearInterval(bt);bt=null;} }
function upBreath(){ const l=document.getElementById('blbl'),n=document.getElementById('bnum'); if(l)l.textContent=phases[ph].lbl;if(n)n.textContent=bc; }

/* ── MENU ── */
function toggleMenu(){
  const dd=document.getElementById('dropdown'),ham=document.getElementById('ham'),ov=document.getElementById('overlay');
  const open=dd.classList.contains('open');
  dd.classList.toggle('open'); ham.classList.toggle('open'); ov.classList.toggle('on');
}
function closeMenu(){ document.getElementById('dropdown').classList.remove('open'); document.getElementById('ham').classList.remove('open'); document.getElementById('overlay').classList.remove('on'); }

/* ── SETTINGS ── */
function openSettings(){ closeMenu(); document.getElementById('set-name').value=userName; document.getElementById('settings-panel').classList.add('open'); }
function closeSettings(){ document.getElementById('settings-panel').classList.remove('open'); }
function panelBgClick(e){ if(e.target===document.getElementById('settings-panel')) closeSettings(); }
function togglePref(el){
  el.classList.toggle('on');
  const prefs=loadPrefs();
  prefs[el.dataset.pref]=el.classList.contains('on');
  savePrefs(prefs);
}

/* ── SIGN OUT ── */
function signOut(){
  closeMenu();
  if(!confirm('Sign out and return to the welcome screen?')) return;
  localStorage.removeItem(NAME_KEY);
  Object.keys(doneSteps).forEach(k=>delete doneSteps[k]);
  for(let i=1;i<=5;i++){ document.getElementById('c'+i).classList.remove('done'); const d=document.getElementById('d'+i);if(d)d.style.display='none'; }
  document.getElementById('home-cta').innerHTML='Begin Morning Ritual <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 2.5l5 5-5 5M2.5 7.5H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>';
  document.getElementById('ob-name').value=''; userName=''; stopBreath();
  document.getElementById(cur).classList.remove('active'); cur='s-onboard'; prev='s-onboard';
  document.getElementById('s-onboard').classList.add('active');
}

/* ── RESET (demo) ── */
function resetDemo(){
  Object.keys(doneSteps).forEach(k=>delete doneSteps[k]);
  for(let i=1;i<=5;i++){ document.getElementById('c'+i).classList.remove('done'); const d=document.getElementById('d'+i);if(d)d.style.display='none'; }
  document.getElementById('home-cta').innerHTML='Begin Morning Ritual <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 2.5l5 5-5 5M2.5 7.5H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>';
  stopBreath(); go('s-home');
}

/* ── THEMES ── */
function setTheme(theme, el){
  const targets=[document.getElementById('app'), document.body, document.getElementById('settings-panel'), document.getElementById('settings-sheet')];
  targets.forEach(t=>{ t.removeAttribute('data-theme'); if(theme!=='gold') t.setAttribute('data-theme',theme); });
  document.querySelectorAll('.theme-swatch').forEach(s=>s.classList.remove('active'));
  el.classList.add('active');
  activeTheme=theme;
  localStorage.setItem(THEME_KEY,theme);
}
function loadPrefs(){
  try{
    return JSON.parse(localStorage.getItem(PREF_KEY)) || {};
  }catch(_){
    return {};
  }
}
function savePrefs(prefs){
  localStorage.setItem(PREF_KEY,JSON.stringify(prefs));
}
function applySavedTheme(){
  const theme=localStorage.getItem(THEME_KEY)||'gold';
  const swatch=document.querySelector(`.theme-swatch[data-theme="${theme}"]`) || document.querySelector('.theme-swatch[data-theme="gold"]');
  if(swatch) setTheme(theme,swatch);
}
function applySavedPrefs(){
  const prefs=loadPrefs();
  document.querySelectorAll('.tog[data-pref]').forEach(t=>{
    const key=t.dataset.pref;
    if(typeof prefs[key]==='boolean'){
      t.classList.toggle('on',prefs[key]);
    }
  });
}
function initApp(){
  applySavedTheme();
  applySavedPrefs();
  const savedName=(localStorage.getItem(NAME_KEY)||'').trim();
  if(savedName){
    userName=savedName;
    document.getElementById('ob-name').value=savedName;
    document.getElementById('set-name').value=savedName;
    document.getElementById('dd-username').textContent='👋 Hey, '+savedName;
    setGreeting(savedName);
    document.getElementById('s-onboard').classList.remove('active');
    cur='s-home';
    prev='s-home';
    document.getElementById('s-home').classList.add('active');
  }
}
initApp();
</script>

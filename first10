<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>First 10 — Start Your Day Right</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --navy: #0f1b2d; --navy2: #162236; --navy3: #1e2f47; --navy4: #253858;
  --gold: #c9a84c; --gold2: #e2b96a;
  --muted: rgba(255,255,255,0.45); --dim: rgba(255,255,255,0.72); --green: #4caf7d;
}
[data-theme="rose"]     { --navy:#1f0d12; --navy2:#2d1219; --navy3:#3d1a24; --navy4:#50222f; --gold:#e07a8a; --gold2:#f0a0ae; }
[data-theme="forest"]   { --navy:#0b1a10; --navy2:#112418; --navy3:#173222; --navy4:#1e402c; --gold:#5cad6e; --gold2:#80c990; }
[data-theme="slate"]    { --navy:#111418; --navy2:#191e25; --navy3:#222830; --navy4:#2c343f; --gold:#7b9fc7; --gold2:#a4bedd; }
[data-theme="amethyst"] { --navy:#140d1f; --navy2:#1e1230; --navy3:#281840; --navy4:#321f52; --gold:#a07ad4; --gold2:#c4a0e8; }

html,body { background:var(--navy); font-family:'DM Sans',sans-serif; color:#fff; min-height:100vh; display:flex; align-items:center; justify-content:center; transition:background .4s; }
.app { width:390px; min-height:100vh; background:var(--navy); display:flex; flex-direction:column; position:relative; overflow:hidden; transition:background .4s; }

.screen { display:none; flex-direction:column; min-height:100vh; }
.screen.active { display:flex; animation:fadeIn .35s ease; }
@keyframes fadeIn { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
@keyframes sunRise { from{opacity:0;transform:scale(.7) translateY(20px)} to{opacity:1;transform:scale(1) translateY(0)} }
@keyframes dropIn  { from{opacity:0;transform:translateY(-8px)} to{opacity:1;transform:translateY(0)} }
@keyframes slideUp { from{transform:translateY(100%)} to{transform:translateY(0)} }
@keyframes bpulse  { 0%,100%{transform:scale(1);border-color:rgba(255,255,255,.15)} 50%{transform:scale(1.14);border-color:rgba(255,255,255,.4)} }

/* ── ONBOARDING ── */
.onboard { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:40px 32px; text-align:center; }
.ob-sun { margin-bottom:32px; animation:sunRise .9s ease-out; }
.onboard h1 { font-family:'Playfair Display',serif; font-size:38px; font-weight:400; margin-bottom:6px; }
.tagline { font-size:15px; color:var(--gold2); margin-bottom:10px; font-weight:300; letter-spacing:.5px; }
.onboard .sub { font-size:13px; color:var(--muted); margin-bottom:36px; }
.ob-label { font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.6px; margin-bottom:8px; text-align:left; width:100%; }
.ob-input { width:100%; background:var(--navy2); border:1.5px solid rgba(255,255,255,.12); border-radius:14px; padding:15px 18px; color:#fff; font-family:'DM Sans',sans-serif; font-size:17px; outline:none; transition:border-color .2s; margin-bottom:18px; text-align:center; }
.ob-input:focus { border-color:var(--gold); }
.ob-input::placeholder { color:rgba(255,255,255,.2); }
.ob-foot { font-size:13px; color:var(--muted); margin-top:14px; font-weight:300; }

/* ── TOP BAR ── */
.top-bar { display:flex; align-items:center; justify-content:space-between; padding:54px 24px 14px; position:relative; z-index:10; }
.hamburger { display:flex; flex-direction:column; gap:5px; cursor:pointer; padding:4px; }
.hamburger span { width:22px; height:1.5px; background:var(--dim); border-radius:2px; display:block; transition:all .25s; }
.hamburger.open span:nth-child(1) { transform:rotate(45deg) translate(4.5px,4.5px); }
.hamburger.open span:nth-child(2) { opacity:0; transform:scaleX(0); }
.hamburger.open span:nth-child(3) { transform:rotate(-45deg) translate(4.5px,-4.5px); }

/* ── DROPDOWN ── */
.overlay { display:none; position:fixed; inset:0; z-index:100; }
.overlay.on { display:block; }
.dropdown { position:absolute; top:108px; left:18px; background:var(--navy2); border:1px solid rgba(255,255,255,.1); border-radius:14px; padding:6px; z-index:200; min-width:185px; display:none; animation:dropIn .2s ease; box-shadow:0 8px 32px rgba(0,0,0,.45); }
.dropdown.open { display:block; }
.dd-item { display:flex; align-items:center; gap:10px; padding:12px 14px; border-radius:10px; cursor:pointer; font-size:14px; transition:background .15s; color:#fff; }
.dd-item:hover { background:var(--navy3); }
.dd-item.danger { color:#f07070; }
.dd-sep { height:1px; background:rgba(255,255,255,.07); margin:4px 0; }
.dd-name { padding:10px 14px 6px; font-size:12px; color:var(--muted); }

/* ── GREETING ── */
.greeting { padding:6px 24px 26px; text-align:center; }
.greeting h1 { font-family:'Playfair Display',serif; font-size:29px; font-weight:400; letter-spacing:-.3px; margin-bottom:5px; }
.greeting p { font-size:14px; color:var(--muted); font-weight:300; }

/* ── CARDS ── */
.cards { padding:0 16px; display:flex; flex-direction:column; gap:10px; flex:1; }
.step-card { background:var(--navy2); border-radius:16px; padding:15px 18px; cursor:pointer; transition:background .2s,transform .15s; border:1px solid rgba(255,255,255,.06); }
.step-card:hover { background:var(--navy3); transform:translateY(-1px); }
.step-card.done { border-color:rgba(255,255,255,.12); }
.step-head { display:flex; align-items:center; justify-content:space-between; }
.step-left { display:flex; align-items:center; gap:11px; }
.step-num { width:26px; height:26px; border-radius:50%; background:var(--navy3); border:1.5px solid rgba(255,255,255,.15); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:500; color:var(--dim); flex-shrink:0; }
.step-icon { width:26px; height:26px; border-radius:50%; background:rgba(255,255,255,.06); display:none; align-items:center; justify-content:center; flex-shrink:0; }
.step-card.done .step-num { display:none; }
.step-card.done .step-icon { display:flex; }
.step-title { font-size:16px; font-weight:500; }
.check-ring { width:24px; height:24px; border-radius:50%; border:1.5px solid rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; transition:all .3s; }
.step-card.done .check-ring { background:rgba(76,175,125,.12); border-color:var(--green); }
.check-ring svg path { opacity:0; }
.step-card.done .check-ring svg path { opacity:1; }
.step-details { margin-top:11px; padding-top:11px; border-top:1px solid rgba(255,255,255,.07); }
.dr { display:flex; gap:18px; }
.di label { font-size:11px; color:var(--muted); display:block; margin-bottom:2px; }
.di span { font-size:14px; font-weight:500; }
.gl { font-size:11px; color:var(--muted); }
.gv { font-size:14px; font-weight:500; margin-bottom:6px; }
.mr { display:flex; align-items:center; justify-content:space-between; }
.play { width:34px; height:34px; border-radius:50%; background:var(--navy4); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; }
.tbadge { background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.14); color:var(--gold2); font-size:12px; padding:3px 10px; border-radius:20px; font-weight:500; }

/* ── CTA ── */
.cta { margin:18px 16px 34px; background:var(--gold); color:var(--navy); border:none; border-radius:14px; padding:17px; font-family:'DM Sans',sans-serif; font-size:15px; font-weight:500; cursor:pointer; width:calc(100% - 32px); display:flex; align-items:center; justify-content:center; gap:7px; transition:filter .2s,transform .15s; }
.cta:hover { filter:brightness(1.1); transform:translateY(-1px); }
.cta:active { transform:scale(.98); }

/* ── DETAIL HEADERS ── */
.dsh { display:flex; align-items:center; gap:13px; padding:54px 24px 18px; }
.back { width:36px; height:36px; border-radius:50%; background:var(--navy2); border:1px solid rgba(255,255,255,.1); display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0; }
.dsh h2 { font-family:'Playfair Display',serif; font-size:24px; font-weight:400; }
.sp { padding:0 24px; }
.hint { font-size:13px; color:var(--muted); margin-bottom:18px; }
.fl { font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px; font-weight:400; }

/* ── MOOD GRID ── */
.mg { display:grid; grid-template-columns:1fr 1fr 1fr; gap:9px; margin-bottom:20px; }
.mc { background:var(--navy2); border-radius:13px; padding:14px 10px; text-align:center; cursor:pointer; border:1.5px solid transparent; transition:all .2s; }
.mc:hover { border-color:rgba(255,255,255,.15); }
.mc.sel { border-color:var(--gold); background:rgba(255,255,255,.04); }
.mc .em { font-size:24px; margin-bottom:5px; }
.mc .lbl { font-size:12px; color:var(--muted); }
.mc.sel .lbl { color:var(--gold2); }

/* ── SLIDERS ── */
.slsec { margin-bottom:22px; }
.sllbl { display:flex; justify-content:space-between; margin-bottom:9px; }
.sllbl span { font-size:14px; color:var(--muted); }
.sllbl strong { color:var(--gold2); font-size:15px; font-weight:500; }
input[type=range] { -webkit-appearance:none; width:100%; height:4px; background:var(--navy3); border-radius:2px; outline:none; }
input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; width:20px; height:20px; border-radius:50%; background:var(--gold); cursor:pointer; border:3px solid var(--navy); }

/* ── TEXT INPUT ── */
.ti { width:100%; background:var(--navy2); border:1px solid rgba(255,255,255,.1); border-radius:12px; padding:13px 15px; color:#fff; font-family:'DM Sans',sans-serif; font-size:15px; outline:none; margin-bottom:12px; transition:border-color .2s; }
.ti:focus { border-color:rgba(255,255,255,.3); }
.ti::placeholder { color:rgba(255,255,255,.22); }

/* ── BREATHING ── */
.bwrap { display:flex; flex-direction:column; align-items:center; padding:26px 24px; }
.bring { width:176px; height:176px; border-radius:50%; border:2px solid rgba(255,255,255,.15); display:flex; align-items:center; justify-content:center; margin-bottom:28px; animation:bpulse 4s ease-in-out infinite; }
.binner { width:126px; height:126px; border-radius:50%; background:rgba(255,255,255,.03); display:flex; align-items:center; justify-content:center; flex-direction:column; }
.btext { font-size:15px; color:var(--gold2); margin-bottom:3px; }
.bnum { font-size:30px; font-weight:300; }
.binst { text-align:center; color:var(--muted); font-size:14px; line-height:1.7; }

/* ── MODE CARDS ── */
.modes { display:flex; gap:9px; margin-top:16px; }
.mcard { flex:1; border-radius:14px; padding:13px 10px; text-align:center; cursor:pointer; transition:all .2s; border:1px solid rgba(255,255,255,.07); background:var(--navy2); }
.mcard.sel { background:rgba(255,255,255,.04); border-color:rgba(255,255,255,.2); }
.mcard .mi { font-size:20px; margin-bottom:5px; }
.mcard .mt { font-size:13px; font-weight:500; }
.mcard .ms { font-size:11px; color:rgba(255,255,255,.3); margin-top:2px; }

/* ── TASKS ── */
.ti2 { background:var(--navy2); border-radius:12px; padding:13px 15px; display:flex; align-items:center; gap:11px; margin-bottom:9px; cursor:pointer; transition:background .2s; border:1px solid rgba(255,255,255,.05); }
.ti2:hover { background:var(--navy3); }
.ti2.done { opacity:.45; }
.tcheck { width:22px; height:22px; border-radius:50%; border:1.5px solid rgba(255,255,255,.22); flex-shrink:0; display:flex; align-items:center; justify-content:center; transition:all .2s; }
.ti2.done .tcheck { background:var(--green); border-color:var(--green); }
.ttext { font-size:15px; flex:1; }
.ti2.done .ttext { text-decoration:line-through; color:var(--muted); }
.ptag { font-size:11px; padding:3px 8px; border-radius:20px; background:rgba(255,255,255,.06); color:var(--gold2); border:1px solid rgba(255,255,255,.1); }

/* ── LOCK IN ── */
.libox { background:var(--navy2); border-radius:15px; padding:17px 22px; width:100%; border:1px solid rgba(255,255,255,.06); margin-bottom:14px; }
.listats { display:flex; gap:9px; width:100%; }
.listat { flex:1; background:var(--navy2); border-radius:13px; padding:13px; text-align:center; border:1px solid rgba(255,255,255,.06); }
.listat .n { font-size:19px; font-weight:300; color:var(--gold2); }
.listat .l { font-size:11px; color:rgba(255,255,255,.32); margin-top:3px; }

/* ── COMPLETION ── */
.cscreen { flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:40px 30px; }
.csun { width:100px; margin-bottom:30px; animation:sunRise .9s ease-out; }
.cscreen h1 { font-family:'Playfair Display',serif; font-size:31px; font-weight:400; margin-bottom:10px; }
.cscreen > p { color:var(--muted); font-size:14px; line-height:1.7; margin-bottom:36px; }
.srow { display:flex; gap:22px; margin-bottom:32px; }
.sbox { background:var(--navy2); border-radius:14px; padding:18px 26px; text-align:center; }
.snum { font-size:27px; font-weight:300; color:var(--gold2); }
.slbl { font-size:12px; color:var(--muted); margin-top:3px; }
.streakline { font-size:14px; color:var(--muted); margin-bottom:26px; }

/* ── SETTINGS PANEL ── */
.settings-panel { position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:300; display:none; align-items:flex-end; justify-content:center; }
.settings-panel.open { display:flex; }
.settings-sheet { background:var(--navy2); border-radius:24px 24px 0 0; padding:24px 24px 48px; width:100%; max-width:390px; animation:slideUp .3s cubic-bezier(.34,1.56,.64,1); max-height:90vh; overflow-y:auto; }
.sheet-handle { width:36px; height:4px; background:rgba(255,255,255,.15); border-radius:2px; margin:0 auto 22px; }
.sheet-title { font-family:'Playfair Display',serif; font-size:20px; font-weight:400; margin-bottom:22px; }
.settings-section { margin-bottom:26px; }
.settings-label { font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.6px; margin-bottom:12px; }

/* theme swatches */
.theme-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:9px; }
.theme-swatch { aspect-ratio:1; border-radius:12px; cursor:pointer; border:2px solid transparent; transition:all .2s; display:flex; align-items:center; justify-content:center; }
.theme-swatch.active { border-color:rgba(255,255,255,.8); }
.sw-check { opacity:0; transition:opacity .2s; }
.theme-swatch.active .sw-check { opacity:1; }

/* toggles */
.toggle-row { display:flex; align-items:center; justify-content:space-between; padding:13px 0; border-bottom:1px solid rgba(255,255,255,.07); }
.toggle-row:last-child { border-bottom:none; }
.toggle-label { font-size:14px; }
.toggle-sub { font-size:12px; color:var(--muted); margin-top:2px; }
.tog { width:44px; height:26px; border-radius:13px; background:var(--navy4); position:relative; cursor:pointer; transition:background .2s; flex-shrink:0; }
.tog.on { background:var(--gold); }
.tog-thumb { width:20px; height:20px; background:#fff; border-radius:50%; position:absolute; top:3px; left:3px; transition:transform .2s; }
.tog.on .tog-thumb { transform:translateX(18px); }
</style>
</head>
<body>
<div class="app" id="app">

  <!-- OVERLAY for dropdown -->
  <div class="overlay" id="overlay" onclick="closeMenu()"></div>

  <!-- DROPDOWN MENU -->
  <div class="dropdown" id="dropdown">
    <div class="dd-name" id="dd-username">👋 Hey there</div>
    <div class="dd-sep"></div>
    <div class="dd-item" onclick="openSettings()">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.2" stroke="white" stroke-width="1.4"/><path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15M3.1 3.1l1.06 1.06M11.84 11.84l1.06 1.06M3.1 12.9l1.06-1.06M11.84 4.16l1.06-1.06" stroke="white" stroke-width="1.4" stroke-linecap="round"/></svg>
      Settings
    </div>
    <div class="dd-sep"></div>
    <div class="dd-item danger" onclick="signOut()">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M10.5 11l3.5-3-3.5-3M14 8H6" stroke="#f07070" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Sign Out
    </div>
  </div>

  <!-- ══════════════════════════════ ONBOARDING ══════════════════════════════ -->
  <div class="screen active" id="s-onboard">
    <div class="onboard">
      <div class="ob-sun">
        <svg width="80" height="64" viewBox="0 0 80 64" fill="none">
          <path d="M40 10C26 10 16 20 16 32C16 44 26 52 40 52C54 52 64 44 64 32C64 20 54 10 40 10Z" fill="var(--gold)" opacity=".88"/>
          <line x1="8" y1="34" x2="72" y2="34" stroke="var(--gold)" stroke-width="1.8" stroke-linecap="round" opacity=".5"/>
          <line x1="40" y1="1" x2="40" y2="6" stroke="var(--gold)" stroke-width="1.8" stroke-linecap="round"/>
          <line x1="14" y1="10" x2="18" y2="14" stroke="var(--gold)" stroke-width="1.8" stroke-linecap="round" opacity=".6"/>
          <line x1="66" y1="10" x2="62" y2="14" stroke="var(--gold)" stroke-width="1.8" stroke-linecap="round" opacity=".6"/>
          <line x1="4" y1="26" x2="9" y2="26" stroke="var(--gold)" stroke-width="1.8" stroke-linecap="round" opacity=".4"/>
          <line x1="76" y1="26" x2="71" y2="26" stroke="var(--gold)" stroke-width="1.8" stroke-linecap="round" opacity=".4"/>
        </svg>
      </div>
      <h1>First 10</h1>
      <p class="tagline">Start your day right.</p>
      <p class="sub">10 minutes. Once a day. That's it.</p>
      <div class="ob-label">What's your name?</div>
      <input class="ob-input" id="ob-name" type="text" placeholder="Enter your name" maxlength="30" autocomplete="off" onkeydown="if(event.key==='Enter')startApp()">
      <button class="cta" style="margin:0;width:100%" onclick="startApp()">
        Begin My Ritual
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 2.5l5 5-5 5M2.5 7.5H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <p class="ob-foot">Your morning ritual awaits.</p>
    </div>
  </div>

  <!-- ══════════════════════════════ HOME ══════════════════════════════ -->
  <div class="screen" id="s-home">
    <div class="top-bar">
      <div class="hamburger" id="ham" onclick="toggleMenu()"><span></span><span></span><span></span></div>
      <svg width="30" height="22" viewBox="0 0 30 22" fill="none">
        <path d="M15 2C10.5 2 7 5.8 7 10C7 14.2 10.5 17 15 17C19.5 17 23 14.2 23 10C23 5.8 19.5 2 15 2Z" fill="var(--gold)" opacity=".88"/>
        <line x1="4" y1="15" x2="26" y2="15" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="1" y1="19" x2="29" y2="19" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" opacity=".45"/>
        <line x1="15" y1="0" x2="15" y2="1.5" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" opacity=".6"/>
        <line x1="3" y1="5" x2="5" y2="7" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" opacity=".5"/>
        <line x1="27" y1="5" x2="25" y2="7" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" opacity=".5"/>
      </svg>
      <div style="width:22px"></div>
    </div>

    <div class="greeting">
      <h1 id="greeting-h1">Good morning.</h1>
      <p>Let's make it a great day.</p>
    </div>

    <div class="cards">
      <!-- 1 Check In -->
      <div class="step-card" id="c1" onclick="go('s-checkin')">
        <div class="step-head">
          <div class="step-left">
            <div class="step-num">1</div>
            <div class="step-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="var(--gold2)" stroke-width="2"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="var(--gold2)" stroke-width="2" stroke-linecap="round"/></svg></div>
            <span class="step-title">Check In</span>
          </div>
          <div class="check-ring" id="ck1"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2 5.5l2.5 2.5 4.5-4.5" stroke="#4caf7d" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        </div>
        <div class="step-details" id="d1" style="display:none">
          <div class="dr">
            <div class="di"><label>Sleep</label><span id="sleep-disp">😴 Good</span></div>
            <div class="di"><label>Energy</label><span id="e-disp">⚡ 7/10</span></div>
            <div class="di"><label>Mood</label><span id="m-disp">🙂 8/10</span></div>
          </div>
        </div>
      </div>
      <!-- 2 Focus -->
      <div class="step-card" id="c2" onclick="go('s-focus')">
        <div class="step-head">
